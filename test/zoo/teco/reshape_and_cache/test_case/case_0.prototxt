op_name: "reshape_and_cache"

input {
  id: "key"
  shape: {
    dims: 512
    dims: 8
    dims: 128
  }
  layout: LAYOUT_NCHW
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data: {
    seed: 42
    upper_bound: 1.0
    lower_bound: -1.0
    distribution: UNIFORM
  }
}

input {
  id: "value"
  shape: {
    dims: 512
    dims: 8
    dims: 128
  }
  layout: LAYOUT_NCHW
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data: {
    seed: 43
    upper_bound: 1.0
    lower_bound: -1.0
    distribution: UNIFORM
  }
}

input {
  id: "slot_mapping"
  shape: {
    dims: 512
  }
