    seed: 45
    upper_bound: 5.0
    lower_bound: 1.0
    distribution: UNIFORM
  }
}

output {
  id: "value_cache"
  shape: {
    dims: 64
    dims: 8
    dims: 16
    dims: 128
  }
  reused: true
  layout: LAYOUT_NCHW
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data: {
    seed: 46
    upper_bound: 5.0
    lower_bound: 1.0
    distribution: UNIFORM
  }
}

tecokernel_param: {
  reshape_and_cache_param: {}
}

